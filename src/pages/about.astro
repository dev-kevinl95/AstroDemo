---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

interface user {
  firstName: string;
  country: string;
  occupation: string;
  hobbies: string[];
}

const pageTitle: string = "About Me";

const identity: user = {
  firstName: "Kevin",
  country: "Lima",
  occupation: "Developer",
  hobbies: ["Dota", "Anime", "Skate"],
};

const skills: string[] = [
  "HTML",
  "CSS",
  "TypeScript",
  "React",
  "Astro",
  "Writing Docs",
];

const happy: boolean = true;
const finished: boolean = false;
const goal: number = 3;

const operatingSystem: string = "Linux";
const quantity: number = 3;
const footwear: string = "boots";
const student: boolean = false;

const skillColor: string = "crimson";
const fontWeight: string = "bold";
const textCase: string = "uppercase";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <style is:global define:vars={{ skillColor, fontWeight, textCase }}>
      h1 {
        color: purple;
        font-size: 4rem;
      }

      .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
      }
    </style>
  </head>

  <BaseLayout pageTitle={pageTitle}>
    <p>Here are a few facts about me:</p>
    <ul>
      <li>My name is {identity.firstName}.</li>
      <li>
        I live in {identity.country} and I work as a {identity.occupation}.
      </li>
      {
        identity.hobbies.length >= 2 && (
          <li>
            Two of my hobbies are: {identity.hobbies[0]} and{" "}
            {identity.hobbies[1]}
          </li>
        )
      }
    </ul>
    <p>My skills are:</p>
    <ul>
      {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>

    {happy && <p>I am happy to be learning Astro!</p>}

    {finished && <p>I finished this tutorial!</p>}

    {
      goal === 3 ? (
        <p>My goal is to finish in 3 days.</p>
      ) : (
        <p>My goal is not 3 days.</p>
      )
    }

    <p>{operatingSystem}</p>
    {student && <p>I am still in school.</p>}
    <p>I have {quantity + 8} pairs of {footwear}</p>
    <p>I am not using a Mac.</p>
  </BaseLayout>
</html>
